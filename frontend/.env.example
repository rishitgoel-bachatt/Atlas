# ── Backend API base ──
VITE_BASE_URL_BACKEND=http://localhost:8001

# ── Keycloak (auth) ──
# Set to `true` to skip Keycloak entirely and read a mock role from
# localStorage['atlas_mock_token']. Must match the backend's KEYCLOAK_SIMULATION setting.
VITE_KEYCLOAK_SIMULATION=false

# Keycloak server + realm + frontend client.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=master
VITE_KEYCLOAK_CLIENT_ID=atlas-prod

# ── External links ──
# Used for "Open in Redash" buttons in the UI; pointing at the local Redash
# stack started by docker-compose works for dev.
VITE_REDASH_URL=http://localhost:5500
